PORT=3001
AUTH_SECRET=change_me_for_production

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=HydroPulse
DATABASE_USER=postgres
DATABASE_PASSWORD=your_postgres_password

# Optional alternative to DATABASE_* variables:
# DATABASE_URL=postgres://postgres:your_postgres_password@localhost:5432/HydroPulse
# DATABASE_SSL=false

# Default local users are created only when the users table is empty.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_VIEWER_USERNAME=viewer
DEFAULT_VIEWER_PASSWORD=viewer123

# Serial import from the Arduino/LoRa base station.
SERIAL_PORT=COM8
SERIAL_BAUD_RATE=9600

# External alert delivery. Telegram CHAT_ID can be @channel_name or numeric channel id.
# The bot must be added to the channel and allowed to post messages.
NOTIFICATIONS_ENABLED=true
NOTIFICATION_TIMEOUT_MS=10000
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_POLLING=true
# Optional comma-separated private chat/channel ids that may use bot commands.
# Leave empty to allow commands from any chat that writes to the bot.
TELEGRAM_ALLOWED_CHAT_IDS=
